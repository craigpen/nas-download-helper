{
  "manifest_version": 3,
  "name": "NAS Download helper",
  "description": "Intercepts magnet links and sends them to Synology Download Station.",
  "version": "1.1.0",
  "permissions": ["storage", "notifications", "tabs", "alarms"],
  "host_permissions": ["<all_urls>"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "NAS Download helper",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
